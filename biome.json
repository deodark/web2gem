{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "files": {
    "includes": [
      "src/**/*.ts",
      "scripts/**/*.mjs",
      "tests/**/*.js",
      "tests/**/*.mjs",
      "*.json",
      "*.mjs"
    ]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noControlCharactersInRegex": "off"
      }
    }
  }
}
